# Remote server SSH config
DEPLOY_HOST=your_server_ip
DEPLOY_PORT=22
DEPLOY_USERNAME=root
DEPLOY_PASSWORD=your_ssh_password
DEPLOY_REMOTE_DIR=/root/project

# Remote .env config (written to remote server on deploy)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=ai_love_daily
MYSQL_USERNAME=your_mysql_user
MYSQL_PASSWORD=your_mysql_password

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DATABASE=0
