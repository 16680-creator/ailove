<view class="chat-page">
  <view class="chat-top glass">
    <view class="title-wrap">
      <text class="page-kicker">AI Companion</text>
      <text class="chat-title">AI 陪伴</text>
    </view>
    <view class="top-actions">
      <view class="icon-btn" bindtap="openConversations">
        <van-icon name="clock-o" size="34rpx" color="#7f5342" />
      </view>
      <view class="icon-btn primary" bindtap="newConversation">
        <van-icon name="plus" size="34rpx" color="#fffaf4" />
      </view>
    </view>
  </view>

  <scroll-view class="message-scroll" scroll-y scroll-with-animation scroll-into-view="{{scrollToView}}">
    <view wx:if="{{messages.length === 0}}" class="welcome">
      <view class="welcome-mark">AI</view>
      <text class="welcome-title">今天想聊点什么？</text>
      <text class="welcome-text">可以写心情、发照片，或者把一个小计划丢给我。</text>
      <view class="prompt-row">
        <view wx:for="{{welcomePrompts}}" wx:key="*this" class="prompt-chip" bindtap="usePrompt" data-text="{{item}}">
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <view class="message-list">
      <view
        wx:for="{{messages}}"
        wx:key="id"
        id="msg-{{item.id}}"
        class="message-row {{item.role === 'user' ? 'mine' : 'ai'}}"
      >
        <view class="avatar {{item.role === 'user' ? 'mine-avatar' : ''}}">
          <text>{{item.role === 'user' ? '我' : 'AI'}}</text>
        </view>
        <view class="bubble {{item.error ? 'error' : ''}}">
          <image
            wx:if="{{item.imageUrl}}"
            class="bubble-image"
            src="{{item.imageUrl}}"
            mode="aspectFill"
            data-url="{{item.imageUrl}}"
            bindtap="previewImage"
          />
          <text wx:if="{{item.content}}" class="bubble-text">{{item.content}}</text>
          <view wx:if="{{item.pending}}" class="typing">
            <van-loading type="spinner" size="28rpx" color="#bb775b" />
            <text>正在回复</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="composer safe-area-bottom">
    <view wx:if="{{previewImage}}" class="image-preview">
      <image src="{{previewImage}}" mode="aspectFill" data-url="{{previewImage}}" bindtap="previewImage" />
      <view class="remove-image" bindtap="removeImage">
        <van-icon name="cross" size="24rpx" color="#fff" />
      </view>
    </view>

    <view class="composer-bar">
      <view class="tool-btn {{uploading ? 'disabled' : ''}}" bindtap="chooseImage">
        <van-icon name="photograph" size="36rpx" color="#7f5342" />
      </view>
      <textarea
        class="message-input"
        value="{{inputText}}"
        auto-height
        maxlength="4000"
        cursor-spacing="22"
        placeholder="写一句想说的话"
        bindinput="onInput"
        disabled="{{loading}}"
      />
      <view class="send-btn {{loading ? 'disabled' : ''}}" bindtap="sendMessage">
        <van-icon name="guide-o" size="36rpx" color="#fffaf4" />
      </view>
    </view>
  </view>
</view>

<van-popup show="{{showConversations}}" position="right" custom-style="width: 74%; height: 100%;" bind:close="closeConversations">
  <view class="conversation-panel">
    <view class="panel-head">
      <text class="panel-title">对话记录</text>
      <view class="icon-btn" bindtap="closeConversations">
        <van-icon name="cross" size="32rpx" color="#7f5342" />
      </view>
    </view>

    <van-empty wx:if="{{conversations.length === 0}}" description="暂无对话" />

    <view class="conversation-list">
      <view
        wx:for="{{conversations}}"
        wx:key="conversationId"
        class="conversation-item {{item.conversationId === conversationId ? 'active' : ''}}"
        bindtap="switchConversation"
        data-id="{{item.conversationId}}"
      >
        <text class="conversation-title">{{item.title || '新的对话'}}</text>
        <text class="conversation-last">{{item.lastMessage || ''}}</text>
      </view>
    </view>
  </view>
</van-popup>
