.chat-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background:
    linear-gradient(180deg, rgba(255, 248, 240, 0.95), rgba(247, 239, 229, 0.92)),
    #f7efe5;
}

.chat-top {
  position: sticky;
  top: 0;
  z-index: 5;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 28rpx 20rpx;
}

.title-wrap {
  min-width: 0;
}

.chat-title {
  display: block;
  font-size: 42rpx;
  line-height: 1.2;
  color: var(--text-primary);
  font-weight: 700;
}

.top-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.icon-btn,
.tool-btn,
.send-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-btn,
.tool-btn {
  background: rgba(255, 251, 245, 0.9);
  border: 1rpx solid var(--cream-edge);
}

.icon-btn.primary,
.send-btn {
  background: linear-gradient(135deg, #d08a6a 0%, #b36b50 100%);
  box-shadow: 0 12rpx 26rpx rgba(179, 107, 80, 0.24);
}

.disabled {
  opacity: 0.48;
}

.message-scroll {
  flex: 1;
  height: 0;
  box-sizing: border-box;
  padding: 28rpx 24rpx 220rpx;
}

.welcome {
  padding: 78rpx 36rpx 40rpx;
  text-align: center;
}

.welcome-mark {
  width: 104rpx;
  height: 104rpx;
  margin: 0 auto 28rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7f5342, #d08a6a);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fffaf4;
  font-size: 32rpx;
  font-weight: 700;
}

.welcome-title,
.welcome-text {
  display: block;
}

.welcome-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.welcome-text {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.prompt-row {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 36rpx;
}

.prompt-chip {
  min-height: 72rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 251, 245, 0.9);
  border: 1rpx solid var(--cream-edge);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--accent-deep);
  font-size: 26rpx;
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 26rpx;
}

.message-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.message-row.mine {
  flex-direction: row-reverse;
}

.avatar {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  background: #efe0d1;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: var(--accent-deep);
  font-size: 22rpx;
  font-weight: 700;
}

.mine-avatar {
  background: var(--accent-deep);
  color: #fffaf4;
}

.bubble {
  max-width: 560rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 253, 249, 0.96);
  border: 1rpx solid rgba(126, 97, 78, 0.1);
  box-shadow: 0 10rpx 24rpx rgba(101, 72, 50, 0.06);
  box-sizing: border-box;
}

.mine .bubble {
  background: linear-gradient(135deg, #d08a6a 0%, #b36b50 100%);
  border-color: transparent;
}

.bubble.error {
  background: #fff4f0;
}

.bubble-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.75;
  color: var(--text-primary);
  word-break: break-word;
}

.mine .bubble-text {
  color: #fffaf4;
}

.bubble-image {
  display: block;
  width: 360rpx;
  height: 360rpx;
  border-radius: 18rpx;
  margin-bottom: 14rpx;
  background: #efe0d1;
}

.typing {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 42rpx;
}

.typing text {
  color: var(--text-light);
  font-size: 24rpx;
}

.composer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 8;
  padding: 18rpx 22rpx 22rpx;
  background: rgba(255, 248, 240, 0.96);
  border-top: 1rpx solid rgba(126, 97, 78, 0.1);
  box-shadow: 0 -14rpx 32rpx rgba(101, 72, 50, 0.06);
  box-sizing: border-box;
}

.composer-bar {
  display: flex;
  align-items: flex-end;
  gap: 14rpx;
}

.message-input {
  flex: 1;
  min-height: 72rpx;
  max-height: 180rpx;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 253, 249, 0.96);
  border: 1rpx solid var(--cream-edge);
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

.image-preview {
  position: relative;
  width: 136rpx;
  height: 136rpx;
  margin: 0 0 16rpx 86rpx;
}

.image-preview image {
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
}

.remove-image {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: rgba(52, 38, 30, 0.78);
  display: flex;
  align-items: center;
  justify-content: center;
}

.conversation-panel {
  min-height: 100%;
  padding: 32rpx 24rpx;
  background: #fff8f0;
  box-sizing: border-box;
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.panel-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.conversation-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.conversation-item {
  padding: 22rpx;
  border-radius: 20rpx;
  background: rgba(255, 253, 249, 0.92);
  border: 1rpx solid var(--cream-edge);
}

.conversation-item.active {
  border-color: rgba(187, 119, 91, 0.55);
  background: rgba(187, 119, 91, 0.08);
}

.conversation-title,
.conversation-last {
  display: block;
}

.conversation-title {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.conversation-last {
  margin-top: 8rpx;
  color: var(--text-light);
  font-size: 23rpx;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
