.page-shell {
  min-height: 100vh;
  background: #f7efe5;
}

.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

/* 菜品大图 */
.dish-hero {
  position: relative;
  width: 100%;
  height: 480rpx;
}

.hero-img {
  width: 100%;
  height: 100%;
  background: #f5ece4;
}

.hero-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 36rpx 32rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.55));
}

.hero-name {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.hero-tags {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 14rpx;
}

.hero-tag {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
  font-size: 22rpx;
  backdrop-filter: blur(4px);
}

/* 区块通用 */
.section {
  margin: 28rpx 30rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(126, 97, 78, 0.06);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 18rpx;
}

.section-header .section-title {
  margin-bottom: 0;
}

.desc-text {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

/* 做法区块 */
.recipe-section {
  margin-bottom: 60rpx;
}

.regen-btn {
  height: 52rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #f8f0ea;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: var(--accent);
  font-weight: 600;
}

.recipe-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  gap: 20rpx;
}

.recipe-loading-text {
  font-size: 26rpx;
  color: var(--text-light);
}

.recipe-content {
  padding: 4rpx 0;
}

.recipe-text {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.8;
  white-space: pre-wrap;
}

.recipe-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 0;
}

.recipe-empty-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #ead7c9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--accent-deep);
}

.recipe-empty-text {
  display: block;
  margin-top: 18rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.gen-btn {
  margin-top: 28rpx;
  height: 68rpx;
  padding: 0 40rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #d08a6a 0%, #b36b50 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(179, 107, 80, 0.3);
}
