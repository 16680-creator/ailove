.article-card {
  padding: 34rpx;
}

.detail-header {
  margin-bottom: 22rpx;
}

.detail-date {
  font-size: 22rpx;
  color: var(--text-light);
}

.mood-tag {
  display: inline-flex;
  align-items: center;
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.mood-1 { background: #fff0de; color: #bf7d30; }
.mood-2 { background: #fbe5e0; color: #b76655; }
.mood-3 { background: #e7eef3; color: #53718b; }
.mood-4 { background: #eee8e1; color: #6d625a; }
.mood-5 { background: #f4dfdd; color: #b65f58; }

.detail-title,
.detail-content {
  display: block;
}

.detail-title {
  font-size: 42rpx;
  line-height: 1.3;
  font-weight: 700;
  color: var(--text-primary);
}

.detail-content {
  margin-top: 22rpx;
  font-size: 30rpx;
  line-height: 1.95;
  color: var(--text-secondary);
  white-space: pre-wrap;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 28rpx;
}

.grid-img {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 20rpx;
}

.author-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(126, 97, 78, 0.1);
}

.author-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.avatar {
  width: 50rpx;
  height: 50rpx;
}

.author-name,
.private-tag {
  font-size: 23rpx;
  color: var(--text-light);
}

.private-tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(126, 97, 78, 0.08);
}

.delete-btn {
  margin-top: 6rpx;
}

.loading-wrap {
  height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
}
