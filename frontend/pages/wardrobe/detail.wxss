.detail-page {
  padding-bottom: 180rpx;
}

.detail-page .page-kicker {
  letter-spacing: 0;
}

.detail-page .card {
  border-radius: 12rpx;
}

.detail-loading {
  margin-top: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 220rpx;
}

.detail-hero {
  position: relative;
  width: 100%;
  height: 760rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #fbf4eb;
  box-shadow: 0 18rpx 44rpx rgba(101, 72, 50, 0.1);
}

.hero-image,
.hero-placeholder {
  width: 100%;
  height: 100%;
}

.hero-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #fbf4eb 0%, #ead7c9 100%);
}

.hero-placeholder text {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #fff9f2;
  color: #bb775b;
  font-size: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-shade {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 230rpx;
  background: linear-gradient(180deg, rgba(52, 38, 30, 0), rgba(52, 38, 30, 0.58));
}

.back-btn {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: rgba(52, 38, 30, 0.36);
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-copy {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 28rpx;
}

.hero-title,
.hero-meta {
  display: block;
  color: #fff9f2;
}

.hero-title {
  font-size: 40rpx;
  line-height: 1.25;
  font-weight: 700;
}

.hero-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(255, 249, 242, 0.86);
}

.recognize-alert {
  margin-top: 24rpx;
  padding: 26rpx;
  border-color: rgba(182, 95, 88, 0.34);
  background: linear-gradient(180deg, rgba(255, 248, 240, 0.98), rgba(255, 239, 232, 0.98));
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.alert-copy {
  flex: 1;
  min-width: 0;
}

.alert-title,
.alert-text {
  display: block;
}

.alert-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #34261e;
}

.alert-text {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #7f5342;
}

.alert-btn {
  flex-shrink: 0;
  height: 62rpx;
  margin: 0;
  padding: 0 22rpx;
  border-radius: 12rpx;
  background: #bb775b;
  color: #fff9f2;
  font-size: 24rpx;
  line-height: 62rpx;
}

.alert-btn::after {
  border: none;
}

.attr-card {
  margin-top: 24rpx;
  padding: 28rpx 0 10rpx;
  overflow: hidden;
}

.attr-card .section-head {
  padding: 0 28rpx;
}

.detail-actions {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 24rpx;
  z-index: 120;
  min-height: 108rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: rgba(255, 249, 242, 0.98);
  border: 1rpx solid rgba(187, 119, 91, 0.18);
  box-shadow: 0 18rpx 46rpx rgba(101, 72, 50, 0.18);
  display: grid;
  grid-template-columns: 1fr 1fr 1.35fr;
  gap: 12rpx;
  box-sizing: border-box;
}

.action-btn {
  height: 74rpx;
  margin: 0;
  padding: 0 12rpx;
  border-radius: 12rpx;
  background: #fbf4eb;
  color: #7f5342;
  font-size: 24rpx;
  line-height: 74rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.action-btn.danger {
  color: #b65f58;
  background: #fff1ed;
}

.action-btn.primary {
  color: #fff;
  background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%);
  font-weight: 600;
}

.action-btn::after {
  border: none;
}

.edit-popup {
  height: 100%;
  padding: 36rpx 30rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  overflow-y: auto;
}

.popup-header {
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.popup-title,
.popup-subtitle {
  display: block;
}

.popup-title {
  font-size: 36rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #34261e;
}

.popup-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8e7b6d;
}

.edit-block {
  margin: 28rpx 0 18rpx;
}

.edit-label {
  display: block;
  margin-bottom: 14rpx;
  font-size: 24rpx;
  color: #6f5d51;
}

.chip-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
}

.occasion-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.edit-chip {
  height: 58rpx;
  padding: 0 10rpx;
  border-radius: 12rpx;
  background: #fff9f2;
  border: 1rpx solid rgba(187, 119, 91, 0.14);
  color: #7f5342;
  font-size: 23rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.edit-chip.active {
  background: #bb775b;
  color: #fff9f2;
  border-color: #bb775b;
  font-weight: 600;
}

.save-btn {
  height: 82rpx;
  margin: 34rpx 0 0;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 82rpx;
}

.save-btn::after {
  border: none;
}
