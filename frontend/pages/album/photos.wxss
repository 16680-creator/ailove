.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
  padding-bottom: 120rpx;
}

.photo-item {
  aspect-ratio: 0.92;
  border-radius: 22rpx;
  overflow: hidden;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 70rpx 40rpx;
  text-align: center;
}

.empty-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #ead7c9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  color: var(--accent-deep);
}

.empty-title,
.empty-text {
  display: block;
}

.empty-title {
  margin-top: 24rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.empty-text {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: var(--text-secondary);
}

.fab {
  position: fixed;
  right: 36rpx;
  bottom: 126rpx;
  width: 102rpx;
  height: 102rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #d08a6a 0%, #b36b50 100%);
  box-shadow: 0 18rpx 30rpx rgba(179, 107, 80, 0.26);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
}

.fab-icon {
  font-size: 52rpx;
  line-height: 1;
  color: #fffaf4;
}

.loading-wrap {
  height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
}
