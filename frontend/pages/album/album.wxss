.album-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  padding-bottom: 120rpx;
}

.album-item {
  overflow: hidden;
  border-radius: 30rpx;
  background: linear-gradient(180deg, rgba(255, 253, 249, 0.98) 0%, rgba(255, 247, 238, 0.98) 100%);
  border: 1rpx solid rgba(126, 97, 78, 0.12);
  box-shadow: 0 16rpx 34rpx rgba(101, 72, 50, 0.08);
}

.album-cover {
  position: relative;
  aspect-ratio: 0.92;
  overflow: hidden;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f6eadf 0%, #ecd7c7 100%);
}

.cover-mark {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(255, 250, 244, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  color: var(--accent-deep);
}

.album-count-badge {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(38, 28, 24, 0.52);
  display: inline-flex;
  align-items: center;
  color: #fffaf4;
  font-size: 20rpx;
}

.album-info {
  padding: 22rpx 22rpx 24rpx;
}

.album-name,
.album-count {
  display: block;
}

.album-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.album-count {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 70rpx 40rpx;
  text-align: center;
}

.empty-icon {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #ead7c9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  color: var(--accent-deep);
}

.empty-title,
.empty-text {
  display: block;
}

.empty-title {
  margin-top: 24rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.empty-text {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: var(--text-secondary);
}

.fab {
  position: fixed;
  right: 36rpx;
  bottom: 126rpx;
  width: 102rpx;
  height: 102rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #d08a6a 0%, #b36b50 100%);
  box-shadow: 0 18rpx 30rpx rgba(179, 107, 80, 0.26);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
}

.fab-icon {
  font-size: 52rpx;
  line-height: 1;
  color: #fffaf4;
}

.popup-wrap {
  padding: 34rpx 30rpx;
}

.popup-header {
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.popup-title,
.popup-subtitle {
  display: block;
}

.popup-title {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.popup-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}
