<view class="page-shell">
  <!-- 顶部标题 -->
  <view class="page-top">
    <text class="page-kicker">What to Eat</text>
    <text class="page-heading">今天吃什么</text>
    <text class="page-subtitle">左右滑动选菜，下单解锁甜蜜小任务</text>
  </view>

  <!-- 点餐主区域 -->
  <view class="order-area">
    <!-- 左侧分类导航 -->
    <scroll-view scroll-y class="category-nav">
      <view
        class="nav-item {{currentCategory === index ? 'active' : ''}}"
        wx:for="{{categoryList}}"
        wx:key="index"
        data-idx="{{index}}"
        bindtap="selectCategory"
      >
        <text>{{item}}</text>
      </view>
    </scroll-view>

    <!-- 右侧菜品列表 -->
    <scroll-view scroll-y class="dish-list">
      <view class="dish-group" wx:if="{{menuList.length > 0}}">
        <view class="group-title">{{categoryList[currentCategory]}}</view>
        <view class="dish-card" wx:for="{{menuList}}" wx:key="id" data-id="{{item.id}}" bindtap="viewDetail">
          <image
            src="{{item.imageUrl || '/images/default-food.png'}}"
            mode="aspectFill"
            class="dish-img"
            lazy-load
          />
          <view class="dish-info">
            <text class="dish-name">{{item.name}}</text>
            <text class="dish-desc" wx:if="{{item.description}}">{{item.description}}</text>
            <view class="dish-meta">
              <text class="dish-tag" wx:if="{{item.category}}">{{categoryList[item.category]}}</text>
              <text class="dish-time" wx:if="{{item.cookTime}}">{{item.cookTime}}分钟</text>
            </view>
          </view>
          <view class="dish-action">
            <view
              class="action-btn minus {{cartMap[item.id] > 0 ? 'show' : ''}}"
              data-id="{{item.id}}"
              catchtap="removeFromCart"
            >
              <text>-</text>
            </view>
            <text class="action-count {{cartMap[item.id] > 0 ? 'show' : ''}}">{{cartMap[item.id] || ''}}</text>
            <view class="action-btn plus" data-id="{{item.id}}" catchtap="addToCart">
              <text>+</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{menuList.length === 0 && !loading}}">
        <text class="empty-icon">食</text>
        <text class="empty-title">还没有菜品</text>
        <text class="empty-text">先加第一道菜吧</text>
      </view>

      <!-- 加载中 -->
      <view class="loading-more" wx:if="{{loading}}">
        <van-loading type="spinner" size="24px" color="#bb775b" />
        <text>正在加载菜单...</text>
      </view>

      <!-- 底部留白（给购物车栏腾位置） -->
      <view style="height: 160rpx;"></view>
    </scroll-view>
  </view>

  <!-- 底部购物车栏 -->
  <view class="cart-bar">
    <view class="cart-left" bindtap="randomDish">
      <view class="cart-icon-wrap">
        <text class="cart-icon">菜</text>
        <view class="cart-badge" wx:if="{{cartCount > 0}}">{{cartCount}}</view>
      </view>
      <text class="cart-label">{{cartCount > 0 ? '已选' + cartCount + '道菜' : '还没选菜哦'}}</text>
    </view>
    <view class="cart-right">
      <view class="cart-history-btn" bindtap="showHistory">
        <text>记录</text>
      </view>
      <view class="cart-btn {{cartCount > 0 ? 'active' : ''}}" bindtap="showOrder">
        <text>选好了</text>
      </view>
    </view>
  </view>

  <!-- 添加菜品按钮 -->
  <view class="fab-btn" bindtap="showAddPopup">
    <text class="fab-icon">+</text>
  </view>
</view>

<!-- 下单确认弹窗 -->
<van-popup show="{{showOrderPopup}}" round bind:close="closeOrder">
  <view class="order-popup">
    <text class="popup-title">确认点餐</text>
    <text class="popup-subtitle">今天想吃这些？</text>

    <scroll-view scroll-y class="order-list">
      <view class="order-item" wx:for="{{cartDishes}}" wx:key="id">
        <image
          src="{{item.imageUrl || '/images/default-food.png'}}"
          mode="aspectFill"
          class="order-item-img"
        />
        <view class="order-item-info">
          <text class="order-item-name">{{item.name}}</text>
          <text class="order-item-count">x{{item.count}}</text>
        </view>
      </view>
    </scroll-view>

    <view class="order-actions">
      <van-button type="default" round bindtap="closeOrder">再想想</van-button>
      <van-button type="primary" round class="btn-gradient" bindtap="confirmOrder">确认下单</van-button>
    </view>
  </view>
</van-popup>

<!-- 小任务弹窗 -->
<van-popup show="{{showTaskPopup}}" round bind:close="closeTask">
  <view class="task-popup">
    <text class="task-emoji">❤</text>
    <text class="task-title">甜蜜任务</text>
    <text class="task-desc">下单成功！请完成以下任务：</text>

    <view class="task-card">
      <text class="task-text">{{currentTask}}</text>
    </view>

    <view class="task-dish" wx:if="{{currentDish}}">
      <text class="task-dish-label">今日推荐：</text>
      <text class="task-dish-name">{{currentDish.name}}</text>
    </view>

    <van-button type="primary" round block class="btn-gradient" bindtap="closeTask">
      好的，我去完成
    </van-button>
  </view>
</van-popup>

<!-- 添加菜品弹窗 -->
<van-popup show="{{showAddPopup}}" round position="bottom" custom-style="height: 72%" bind:close="closeAddPopup">
  <view class="add-popup">
    <view class="add-popup-header">
      <text class="add-popup-title">新增菜品</text>
      <text class="add-popup-subtitle">把常吃的味道录进菜单里</text>
    </view>
    <scroll-view scroll-y class="add-form-scroll">
      <van-field
        label="菜品名称"
        value="{{addForm.name}}"
        placeholder="请输入菜品名称"
        required
        bind:input="onNameInput"
      />
      <van-field
        label="分类"
        readonly
        value="{{categoryList[addForm.category]}}"
        placeholder="选择分类"
        is-link
        bind:tap="showCategoryPicker"
      />
      <van-field
        label="烹饪时间"
        value="{{addForm.cookTime}}"
        placeholder="请输入烹饪时长（分钟）"
        type="number"
        bind:input="onCookTimeInput"
      />
      <van-field
        label="难度"
        readonly
        value="{{difficultyStars}}"
        placeholder="选择难度"
        is-link
        bind:tap="showDifficultyPicker"
      />
      <van-field
        label="描述"
        value="{{addForm.description}}"
        placeholder="简单写一下这道菜的特点"
        type="textarea"
        autosize
        bind:input="onDescInput"
      />
      <view class="upload-section">
        <text class="upload-label">菜品图片</text>
        <van-uploader
          file-list="{{fileList}}"
          max-count="1"
          bind:after-read="afterRead"
          bind:delete="deleteImage"
        />
      </view>
    </scroll-view>
    <view class="add-popup-actions">
      <van-button type="primary" round block class="btn-gradient" bindtap="submitAdd">
        确认添加
      </van-button>
    </view>
  </view>
</van-popup>

<!-- 餐食记录弹窗 -->
<van-popup show="{{showHistoryPopup}}" round position="bottom" custom-style="height: 75%" bind:close="closeHistory">
  <view class="history-popup">
    <view class="history-header">
      <text class="history-title">用餐记录</text>
      <text class="history-subtitle">最近7天吃了什么</text>
    </view>

    <!-- 加载中 -->
    <view class="history-loading" wx:if="{{historyLoading}}">
      <van-loading type="spinner" size="24px" color="#bb775b" />
      <text>加载中...</text>
    </view>

    <!-- 空状态 -->
    <view class="history-empty" wx:elif="{{Object.keys(mealHistory).length === 0}}">
      <text class="history-empty-icon">食</text>
      <text class="history-empty-text">还没有用餐记录</text>
    </view>

    <!-- 记录列表 -->
    <scroll-view scroll-y class="history-list" wx:else>
      <view class="history-day" wx:for="{{mealHistory}}" wx:for-index="date" wx:for-item="records" wx:key="date">
        <view class="history-date">
          <text class="history-date-text">{{date}}</text>
        </view>
        <view class="history-record" wx:for="{{records}}" wx:for-item="record" wx:key="id">
          <view class="history-dishes">
            <view class="history-dish" wx:for="{{record.dishes}}" wx:for-item="dish" wx:key="menuItemId">
              <image src="{{dish.imageUrl || '/images/default-food.png'}}" mode="aspectFill" class="history-dish-img" />
              <view class="history-dish-info">
                <text class="history-dish-name">{{dish.name}}</text>
                <text class="history-dish-count">x{{dish.count}}</text>
              </view>
            </view>
          </view>

          <!-- 已评价 -->
          <view class="history-review" wx:if="{{record.rating}}">
            <view class="history-stars">
              <text wx:for="{{5}}" wx:for-index="starIdx" wx:key="starIdx" class="history-star {{starIdx < record.rating ? 'active' : ''}}">★</text>
            </view>
            <text class="history-review-text" wx:if="{{record.comment}}">{{record.comment}}</text>
            <text class="history-reviewer">—— {{record.reviewByName}}</text>
          </view>

          <!-- 未评价，显示评价按钮 -->
          <view class="history-review-pending" wx:elif="{{record.canReview}}">
            <view class="review-btn" data-id="{{record.id}}" bindtap="openReview">
              <text>写评价</text>
            </view>
          </view>

          <view class="history-order-user">
            <text>{{record.userNickname}} 下单</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</van-popup>

<!-- 评价弹窗 -->
<van-popup show="{{showReviewPopup}}" round bind:close="closeReview">
  <view class="review-popup">
    <text class="review-popup-title">餐后评价</text>
    <text class="review-popup-subtitle">这顿饭怎么样？</text>

    <!-- 星星评分 -->
    <view class="review-stars-row">
      <view
        class="review-star {{item ? 'active' : ''}}"
        wx:for="{{reviewStars}}"
        wx:key="index"
        data-idx="{{index}}"
        bindtap="selectStar"
      >
        <text>★</text>
      </view>
    </view>

    <!-- 文字评价 -->
    <van-field
      type="textarea"
      placeholder="说说这顿饭的感受..."
      value="{{reviewForm.comment}}"
      autosize
      border="{{false}}"
      bind:input="onReviewCommentInput"
      custom-style="background: #f8f4f0; border-radius: 16rpx; margin: 24rpx 0;"
    />

    <view class="review-actions">
      <van-button type="default" round bindtap="closeReview">取消</van-button>
      <van-button type="primary" round class="btn-gradient" bindtap="submitReview">提交评价</van-button>
    </view>
  </view>
</van-popup>

<van-action-sheet
  show="{{showCategorySheet}}"
  actions="{{categoryActions}}"
  bind:close="closeCategorySheet"
  bind:select="onCategorySelect"
/>

<van-action-sheet
  show="{{showDifficultySheet}}"
  actions="{{difficultyActions}}"
  bind:close="closeDifficultySheet"
  bind:select="onDifficultySelect"
/>

<van-toast id="van-toast" />
