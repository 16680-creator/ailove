/* 点餐式布局 */
.order-area {
  display: flex;
  height: calc(100vh - 280rpx);
  overflow: hidden;
}

/* 左侧分类导航 */
.category-nav {
  width: 180rpx;
  height: 100%;
  background: #f8f4f0;
  flex-shrink: 0;
}

.nav-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  position: relative;
  transition: all 0.2s;
}

.nav-item.active {
  background: #fff;
  color: var(--accent-deep);
  font-weight: 700;
}

.nav-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 6rpx;
  border-radius: 0 6rpx 6rpx 0;
  background: var(--accent);
}

/* 右侧菜品列表 */
.dish-list {
  flex: 1;
  height: 100%;
  padding-left: 18rpx;
}

.group-title {
  padding: 28rpx 20rpx 18rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

/* 菜品卡片 */
.dish-card {
  display: flex;
  align-items: center;
  padding: 20rpx 20rpx 20rpx 0;
  border-bottom: 1rpx solid rgba(126, 97, 78, 0.08);
}

.dish-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
  background: #f5ece4;
}

.dish-info {
  flex: 1;
  margin-left: 20rpx;
  overflow: hidden;
}

.dish-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
}

.dish-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-light);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 10rpx;
}

.dish-tag {
  display: inline-flex;
  align-items: center;
  height: 36rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #ecdbcf;
  color: var(--accent-deep);
  font-size: 20rpx;
}

.dish-time {
  font-size: 20rpx;
  color: var(--text-light);
}

/* +/- 按钮 */
.dish-action {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
  margin-left: 10rpx;
}

.action-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1;
}

.action-btn.plus {
  background: var(--accent);
  color: #fff;
}

.action-btn.minus {
  background: #fff;
  border: 2rpx solid var(--accent);
  color: var(--accent);
  opacity: 0;
  transform: scale(0.8);
  transition: all 0.2s;
}

.action-btn.minus.show {
  opacity: 1;
  transform: scale(1);
}

.action-count {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-primary);
  min-width: 30rpx;
  text-align: center;
  opacity: 0;
  transition: opacity 0.2s;
}

.action-count.show {
  opacity: 1;
}

/* 底部购物车栏 */
.cart-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #3f2d25;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -8rpx 30rpx rgba(63, 45, 37, 0.15);
}

.cart-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.cart-icon-wrap {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #5a4038;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: -30rpx;
}

.cart-icon {
  font-size: 32rpx;
  color: #fffaf4;
  font-weight: 700;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 999rpx;
  background: var(--accent);
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.cart-label {
  font-size: 26rpx;
  color: rgba(255, 250, 244, 0.8);
}

.cart-btn {
  height: 72rpx;
  padding: 0 40rpx;
  border-radius: 999rpx;
  background: #5a4038;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(255, 250, 244, 0.5);
}

.cart-btn.active {
  background: linear-gradient(135deg, #d08a6a 0%, #b36b50 100%);
  color: #fffaf4;
  box-shadow: 0 8rpx 20rpx rgba(179, 107, 80, 0.3);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
  text-align: center;
}

.empty-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #ead7c9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--accent-deep);
}

.empty-title {
  display: block;
  margin-top: 24rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.empty-text {
  display: block;
  margin-top: 14rpx;
  font-size: 25rpx;
  color: var(--text-secondary);
}

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx 0;
  font-size: 24rpx;
  color: var(--text-light);
}

/* 下单确认弹窗 */
.order-popup {
  width: 600rpx;
  padding: 42rpx 34rpx 34rpx;
}

.popup-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.popup-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.order-list {
  max-height: 500rpx;
  margin-top: 24rpx;
}

.order-item {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(126, 97, 78, 0.08);
}

.order-item-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
  background: #f5ece4;
}

.order-item-info {
  flex: 1;
  margin-left: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.order-item-count {
  font-size: 26rpx;
  color: var(--accent);
  font-weight: 700;
}

.order-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 30rpx;
}

.order-actions van-button {
  flex: 1;
}

/* 小任务弹窗 */
.task-popup {
  width: 560rpx;
  padding: 50rpx 40rpx 40rpx;
  text-align: center;
}

.task-emoji {
  font-size: 64rpx;
  display: block;
}

.task-title {
  display: block;
  margin-top: 20rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.task-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.task-card {
  margin: 30rpx 0;
  padding: 36rpx 30rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #f8f0ea 0%, #f0e4da 100%);
  border: 1rpx solid rgba(187, 119, 91, 0.15);
}

.task-text {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--accent-deep);
  line-height: 1.5;
}

.task-dish {
  margin-bottom: 30rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.task-dish-label {
  color: var(--text-light);
}

.task-dish-name {
  color: var(--accent);
  font-weight: 600;
}

/* 添加菜品 FAB 按钮 */
.fab-btn {
  position: fixed;
  right: 36rpx;
  bottom: 260rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #d08a6a 0%, #b36b50 100%);
  box-shadow: 0 16rpx 28rpx rgba(179, 107, 80, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
}

.fab-icon {
  font-size: 48rpx;
  color: #fffaf4;
  font-weight: 300;
  line-height: 1;
}

/* 添加菜品弹窗 */
.add-popup {
  height: 100%;
  display: flex;
  flex-direction: column;
  padding: 34rpx 30rpx;
}

.add-popup-header {
  margin-bottom: 22rpx;
}

.add-popup-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.add-popup-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.add-form-scroll {
  flex: 1;
}

.upload-section {
  padding: 24rpx 32rpx;
}

.upload-label {
  display: block;
  margin-bottom: 14rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.add-popup-actions {
  padding-top: 18rpx;
}

/* 购物车栏右侧区域 */
.cart-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

/* 记录按钮 */
.cart-history-btn {
  height: 72rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #5a4038;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 250, 244, 0.7);
}

/* ========== 餐食记录弹窗 ========== */
.history-popup {
  height: 100%;
  display: flex;
  flex-direction: column;
  padding: 34rpx 30rpx;
}

.history-header {
  margin-bottom: 24rpx;
}

.history-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.history-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.history-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 80rpx 0;
  font-size: 24rpx;
  color: var(--text-light);
}

.history-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.history-empty-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #ead7c9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: var(--accent-deep);
}

.history-empty-text {
  display: block;
  margin-top: 20rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.history-list {
  flex: 1;
}

.history-day {
  margin-bottom: 28rpx;
}

.history-date {
  padding: 8rpx 0 16rpx;
}

.history-date-text {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--accent-deep);
}

.history-record {
  background: #f8f4f0;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.history-dishes {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.history-dish {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.history-dish-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #f5ece4;
}

.history-dish-info {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.history-dish-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.history-dish-count {
  font-size: 24rpx;
  color: var(--accent);
  font-weight: 600;
}

.history-review {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(126, 97, 78, 0.1);
}

.history-stars {
  display: flex;
  gap: 4rpx;
}

.history-star {
  font-size: 28rpx;
  color: #ddd;
}

.history-star.active {
  color: #f5a623;
}

.history-review-text {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.history-reviewer {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-light);
  text-align: right;
}

.history-review-pending {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(126, 97, 78, 0.1);
  display: flex;
  justify-content: flex-end;
}

.review-btn {
  height: 56rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #d08a6a 0%, #b36b50 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
}

.history-order-user {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--text-light);
}

/* ========== 评价弹窗 ========== */
.review-popup {
  width: 600rpx;
  padding: 42rpx 34rpx 34rpx;
}

.review-popup-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.review-popup-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.review-stars-row {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-top: 36rpx;
}

.review-star {
  font-size: 56rpx;
  color: #ddd;
  transition: color 0.15s;
}

.review-star.active {
  color: #f5a623;
}

.review-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.review-actions van-button {
  flex: 1;
}
