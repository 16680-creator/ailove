page {
  --cream-base: #f7efe5;
  --cream-surface: #fff8f0;
  --cream-surface-strong: #fffdf8;
  --cream-edge: rgba(126, 97, 78, 0.14);
  --accent: #bb775b;
  --accent-deep: #7f5342;
  --accent-soft: #ebd2c3;
  --accent-wash: rgba(187, 119, 91, 0.1);
  --text-primary: #34261e;
  --text-secondary: #6f5d51;
  --text-light: #a59487;
  --border-color: rgba(126, 97, 78, 0.12);
  --card-bg: linear-gradient(180deg, rgba(255, 253, 249, 0.98) 0%, rgba(255, 247, 238, 0.98) 100%);
  --shadow: 0 18rpx 44rpx rgba(101, 72, 50, 0.08);

  background:
    radial-gradient(circle at top left, rgba(237, 216, 198, 0.54), transparent 34%),
    radial-gradient(circle at top right, rgba(250, 232, 216, 0.62), transparent 30%),
    linear-gradient(180deg, #f8f0e6 0%, #f4ede3 52%, #f7f2ea 100%);
  min-height: 100vh;
  color: var(--text-primary);
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

.glass {
  background: rgba(255, 250, 242, 0.78);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.card {
  background: var(--card-bg);
  border-radius: 32rpx;
  border: 1rpx solid var(--border-color);
  box-shadow: var(--shadow);
  margin: 0 0 24rpx;
  padding: 32rpx;
  box-sizing: border-box;
}

.btn-gradient {
  background: linear-gradient(135deg, #d08a6a 0%, #b36b50 100%);
  color: #fffaf4;
  border-radius: 999rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 14rpx 30rpx rgba(179, 107, 80, 0.24);
}

.page-shell {
  box-sizing: border-box;
  padding: 28rpx 24rpx 148rpx;
}

.page-top {
  padding: 10rpx 8rpx 22rpx;
}

.page-kicker {
  display: block;
  margin-bottom: 14rpx;
  font-size: 20rpx;
  color: var(--accent);
  letter-spacing: 6rpx;
  text-transform: uppercase;
}

.page-heading {
  display: block;
  font-size: 52rpx;
  line-height: 1.15;
  font-weight: 700;
  color: var(--text-primary);
}

.page-subtitle {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.section-link {
  font-size: 24rpx;
  color: var(--accent);
}

.section-note {
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-light);
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: var(--accent-wash);
  color: var(--accent-deep);
  font-size: 22rpx;
}

.meta-line {
  font-size: 22rpx;
  color: var(--text-light);
}

.divider-line {
  height: 1rpx;
  background: linear-gradient(90deg, rgba(187, 119, 91, 0.18), rgba(187, 119, 91, 0));
}

.surface-note {
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 251, 245, 0.84);
  border: 1rpx solid rgba(187, 119, 91, 0.12);
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.fade-in {
  animation: fadeIn 0.45s ease-out;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }

  50% {
    transform: scale(1.03);
  }
}

.pulse {
  animation: pulse 2s infinite;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0);
  }

  50% {
    transform: translateY(-8rpx);
  }
}

.float {
  animation: float 3s ease-in-out infinite;
}

.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.ml-10 { margin-left: 10rpx; }
.mr-10 { margin-right: 10rpx; }

.text-xs { font-size: 22rpx; }
.text-sm { font-size: 26rpx; }
.text-base { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-2xl { font-size: 40rpx; }

.text-primary { color: var(--accent); }
.text-dark { color: var(--text-primary); }
.text-gray { color: var(--text-secondary); }
.text-light { color: var(--text-light); }

.rounded { border-radius: 12rpx; }
.rounded-lg { border-radius: 24rpx; }
.rounded-full { border-radius: 50%; }

.popup-wrap {
  padding: 36rpx 32rpx;
  padding-bottom: calc(36rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(36rpx + env(safe-area-inset-bottom));
}

.popup-header {
  margin-bottom: 28rpx;
}

.popup-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.popup-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-light);
}

::-webkit-scrollbar {
  display: none;
}
